generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}



enum KeyStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Key {
  id           Int       @id @default(autoincrement())
  keyName      String    @unique          // e.g. "user@verity.local"
  pubkey       String
  encryptedKey String                      // AES-256-GCM ciphertext (hex)
  iv           String                      // Initialization vector (hex)
  authTag      String                      // GCM authentication tag (hex)
  backedUpAt   DateTime?                   // When backup confirmed
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  status       KeyStatus @default(ACTIVE)  // Account lifecycle state
  statusAt     DateTime?                   // When status last changed
  sessions     Session[]
}

model Session {
  id           Int                @id @default(autoincrement())
  keyName      String
  clientPubkey String                              // Authorized device/browser pubkey
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  description  String?
  key          Key                @relation(fields: [keyName], references: [keyName])
  conditions   SigningCondition[]
  policies     Policy[]

  @@unique([keyName, clientPubkey])
}

model SigningCondition {
  id        Int      @id @default(autoincrement())
  method    String?                     // "sign_event", "encrypt", "connect", "*"
  kind      Int?                        // Event kind filter (null = all kinds)
  allowed   Boolean?                    // true=allow, false=deny, null=undecided
  sessionId Int?
  session   Session? @relation(fields: [sessionId], references: [id])
}

model Policy {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rules       PolicyRule[]
  sessions    Session[]                    // M:N — policy applies to sessions
}

model PolicyRule {
  id                Int     @id @default(autoincrement())
  method            String               // "sign_event", "connect", etc.
  kind              Int?                 // Event kind filter (null = all kinds)
  maxUsageCount     Int?                 // NULL = unlimited
  currentUsageCount Int      @default(0)
  policyId          Int?
  policy            Policy?  @relation(fields: [policyId], references: [id])
}

model Audit {
  id           String   @id @default(uuid())
  keyName      String?
  createdAt    DateTime @default(now())
  correlationId String
  clientPubkey String
  method       String
  params       String?
  allowed      Boolean?
}
